      "source": [
        "# Missing-value indicators"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": [
        "def add_missing_indicators(df, columns):\n    df = df.copy()\n    for col in columns:\n        df[f\"{col}_is_missing\"] = df[col].isna().astype(int)\n    return df\n"
      ]
    }
  ],
